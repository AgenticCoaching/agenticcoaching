{
  "id": "connector-strava",
  "name": "Strava connector",
  "type": "connector",
  "version": "0.1.1",
  "description": "Local coaching-focused Strava MCP for athlete profile, workout data, routes, and scheduled polling sync.",
  "capabilities": [
    "fetch-athlete-profile",
    "fetch-athlete-zones",
    "fetch-athlete-stats",
    "fetch-activities",
    "fetch-activity-detail",
    "fetch-activity-laps",
    "fetch-activity-zones",
    "fetch-activity-streams",
    "update-activity-metadata",
    "fetch-gear",
    "fetch-routes",
    "export-route-gpx",
    "export-route-tcx",
    "store-workout-day-folder",
    "sync-polling"
  ],
  "inputs": [
    "date-range",
    "activity-id",
    "athlete-id",
    "route-id",
    "gear-id"
  ],
  "outputs": [
    "activities",
    "activity-bundles",
    "streams",
    "route-files"
  ],
  "dependencies": [],
  "status": "beta"
}
